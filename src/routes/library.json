{
	"name": "@fuzdev/fuz_docs",
	"repo_name": "fuz_docs",
	"repo_url": "https://github.com/fuzdev/fuz_docs",
	"owner_name": "fuzdev",
	"homepage_url": "https://docs.fuz.dev/",
	"logo_url": "https://docs.fuz.dev/logo.svg",
	"logo_alt": "a friendly pixelated spider facing you",
	"npm_url": null,
	"changelog_url": null,
	"published": false,
	"package_json": {
		"name": "@fuzdev/fuz_docs",
		"version": "0.0.1",
		"description": "experimental AI-generated docs and skills for Fuz, a zippy stack for autonomy",
		"glyph": "📜",
		"logo": "logo.svg",
		"logo_alt": "a friendly pixelated spider facing you",
		"homepage": "https://docs.fuz.dev/",
		"repository": "https://github.com/fuzdev/fuz_docs",
		"scripts": {
			"start": "gro dev",
			"dev": "gro dev",
			"build": "gro build",
			"check": "gro check",
			"test": "gro test",
			"preview": "vite preview",
			"deploy": "gro deploy"
		},
		"type": "module",
		"engines": {
			"node": ">=22.15"
		},
		"devDependencies": {
			"@fuzdev/blake3_wasm": "^0.1.0",
			"@fuzdev/fuz_code": "^0.45.1",
			"@fuzdev/fuz_css": "^0.58.0",
			"@fuzdev/fuz_ui": "^0.191.4",
			"@fuzdev/fuz_util": "^0.55.0",
			"@fuzdev/gro": "^0.197.3",
			"@jridgewell/trace-mapping": "^0.3.31",
			"@ryanatkn/eslint-config": "^0.10.1",
			"@sveltejs/acorn-typescript": "^1.0.9",
			"@sveltejs/adapter-static": "^3.0.10",
			"@sveltejs/kit": "^2.57.1",
			"@sveltejs/vite-plugin-svelte": "^6.2.4",
			"@types/estree": "^1.0.8",
			"@types/node": "^24.10.13",
			"@webref/css": "^8.2.0",
			"eslint": "^9.39.1",
			"eslint-plugin-svelte": "^3.13.1",
			"esm-env": "^1.2.2",
			"magic-string": "^0.30.21",
			"prettier": "^3.7.4",
			"prettier-plugin-svelte": "^3.5.1",
			"svelte": "^5.55.3",
			"svelte-check": "^4.4.5",
			"svelte2tsx": "^0.7.52",
			"tslib": "^2.8.1",
			"typescript": "^5.9.3",
			"typescript-eslint": "^8.48.1",
			"vite": "^7.3.1",
			"vitest": "^4.0.15",
			"zimmerframe": "^1.1.4",
			"zod": "^4.3.6"
		},
		"prettier": {
			"plugins": ["prettier-plugin-svelte"],
			"useTabs": true,
			"printWidth": 100,
			"singleQuote": true,
			"bracketSpacing": false,
			"overrides": [
				{
					"files": "package.json",
					"options": {
						"useTabs": false
					}
				}
			]
		},
		"sideEffects": ["**/*.css"],
		"files": ["dist"]
	},
	"source_json": {
		"name": "@fuzdev/fuz_docs",
		"version": "0.0.1",
		"modules": [
			{
				"path": "DataInput.svelte",
				"declarations": [
					{
						"name": "DataInput",
						"kind": "component",
						"props": [
							{
								"name": "value",
								"type": "Uint8Array | null",
								"optional": true,
								"description": "The normalized binary output. `null` when input is empty or invalid.",
								"bindable": true
							},
							{
								"name": "input_mode",
								"type": "Input_Mode",
								"optional": true,
								"description": "The current input mode.",
								"bindable": true
							},
							{
								"name": "children",
								"type": "Snippet",
								"optional": true
							}
						],
						"source_line": 1
					}
				]
			}
		]
	}
}
